apiVersion: apps/v1
kind: Deployment
metadata:
  name: SHARD_NAME-pri
  labels:
    purpose: SHARD_NAME-pri
  namespace: dev
spec:
  selector:
    matchLabels:
      purpose: SHARD_NAME-pri
  replicas: 1
  strategy:
    type: RollingUpdate
  template:
      metadata:
        labels:
          purpose: SHARD_NAME-pri
      spec:
        terminationGracePeriodSeconds: 5
        volumes:
          - name: startup-config
            configMap:
              name: mongo-rs-config-SHARD_NAME
          - name: kickstart-SHARD_NAME
            configMap:
              name: kickstart-SHARD_NAME
              defaultMode: 0777
          - name: filestore
            persistentVolumeClaim:
              claimName: filestore 
        containers:
          - image: mongo
            name: mongo-db-container
            command:
              - "/bin/sh"
              - "-c"
              - "/kickstart/app-support-pri.sh"
            ports:
              - containerPort: 27018
              - containerPort: 9091
            volumeMounts:
              - name: startup-config
                mountPath: /config/
              - name: kickstart-SHARD_NAME
                mountPath: /kickstart/
              - name: filestore
                mountPath: /filestore/
